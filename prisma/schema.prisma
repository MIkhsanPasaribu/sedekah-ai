// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== ENUMS =====

enum DonationType {
  zakat_mal
  zakat_fitrah
  sedekah
  infaq
  wakaf
  bencana
}

enum DonationStatus {
  pending
  paid
  failed
  expired
}

enum CampaignCategory {
  yatim
  bencana
  kesehatan
  pendidikan
  pangan
}

enum FraudFlagType {
  narrative_manipulation
  financial_anomaly
  seasonal_pattern
  identity_unverified
}

enum FraudSeverity {
  low
  medium
  high
  critical
}

enum MessageRole {
  user
  assistant
  system
}

enum UserRole {
  donor
  admin
}

enum DisbursementStatus {
  pending
  processing
  completed
  verified
}

// ===== MODELS =====

model User {
  id              String   @id @default(uuid())
  authId          String   @unique
  email           String   @unique
  name            String?
  mobile          String?
  mayarCustomerId String?
  role            UserRole @default(donor)
  ramadhanStreak  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  donations        Donation[]
  givingJourney    GivingJourney[]
  conversations    Conversation[]
  disbursements    Disbursement[]
  autopilotConfig  AutopilotConfig?
  createdCampaigns Campaign[] @relation("CampaignCreator")

  @@map("users")
}

model Donation {
  id               String         @id @default(uuid())
  userId           String
  amount           Int
  type             DonationType
  donorIntent      String?
  campaignId       String?
  mayarInvoiceId   String?
  mayarPaymentLink String?
  status           DonationStatus @default(pending)
  paidAt           DateTime?
  impactScore      Int?
  islamicContext   String?
  reflectionSent   Boolean        @default(false)
  createdAt        DateTime       @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([campaignId])
  @@index([status])
  @@index([mayarInvoiceId])
  @@index([createdAt])
  @@map("donations")
}

model Campaign {
  id              String           @id @default(uuid())
  name            String
  description     String
  laz             String
  lazVerified     Boolean          @default(false)
  targetAmount    Int
  collectedAmount Int              @default(0)
  trustScore      Int              @default(0)
  trustBreakdown  Json?
  category        CampaignCategory
  region          String
  isActive        Boolean          @default(true)
  fraudFlags      Int              @default(0)
  endsAt          DateTime?
  creatorId       String?
  createdAt       DateTime         @default(now())

  donations      Donation[]
  fraudAlerts    FraudFlag[]
  disbursements  Disbursement[]
  creator        User?            @relation("CampaignCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([isActive])
  @@index([trustScore])
  @@map("campaigns")
}

model FraudFlag {
  id          String        @id @default(uuid())
  campaignId  String
  flagType    FraudFlagType
  description String
  severity    FraudSeverity
  detectedAt  DateTime      @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("fraud_flags")
}

model GivingJourney {
  id           String   @id @default(uuid())
  userId       String
  ramadhanDay  Int
  donated      Boolean  @default(false)
  amount       Int      @default(0)
  nudgeMessage String?
  milestone    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ramadhanDay])
  @@index([userId])
  @@map("giving_journey")
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  threadId  String   @unique
  title     String   @default("Percakapan Baru")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model LazPartner {
  id            String   @id @default(uuid())
  name          String   @unique
  bankName      String
  accountNumber String
  accountHolder String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  disbursements Disbursement[]

  @@map("laz_partners")
}

model Disbursement {
  id               String             @id @default(uuid())
  campaignId       String
  lazPartnerId     String?
  amount           Int
  recipientLaz     String
  recipientAccount String?
  bankName         String?
  accountHolder    String?
  status           DisbursementStatus @default(pending)
  transferProof    String?
  notes            String?
  disbursedAt      DateTime?
  verifiedAt       DateTime?
  disbursedById    String
  createdAt        DateTime           @default(now())

  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  disbursedBy User        @relation(fields: [disbursedById], references: [id])
  lazPartner  LazPartner? @relation(fields: [lazPartnerId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([status])
  @@index([lazPartnerId])
  @@map("disbursements")
}

model AutopilotConfig {
  id            String   @id @default(uuid())
  userId        String   @unique
  monthlyAmount Int
  categories    String[]
  isActive      Boolean  @default(false)
  nextRunAt     DateTime?
  lastRunAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("autopilot_configs")
}
